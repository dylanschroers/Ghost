{
  "name": "ghost",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "desktop": "pnpm --filter @ghost/desktop dev:desktop",
    "desktop:build": "pnpm --filter @ghost/desktop build:desktop",
    "fetch-assets": "bash scripts/fetch-assets.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3", "@tauri-apps/cli"]
  }
}
