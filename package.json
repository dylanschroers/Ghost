{
  "name": "ghost",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "desktop": "pnpm --filter @ghost/desktop dev:desktop",
    "desktop:build": "pnpm --filter @ghost/desktop build:desktop",
    "fetch-assets": "node scripts/fetch-assets.mjs",
    "tool-eval": "tsx scripts/tool-eval.ts"
  },
  "devDependencies": {
    "@ghost/shared": "workspace:^",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "@tauri-apps/cli"
    ]
  }
}
