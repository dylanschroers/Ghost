# Copy this file to .env and fill in the values. .env is gitignored.
# apps/server/src/env.ts loads it into process.env at startup.

# Unsloth Studio bearer + base URL. Inference (UnslothEngine) and the Model Lab
# (StudioClient) both read these, so training and chat always hit the same
# Studio. The key is minted by Studio and stored in
# ~/.unsloth/studio/auth/agent_api_key.json (the "minted" entry for the matching
# server URL). Studio answers /v1/models with 401 when the key is missing.
UNSLOTH_API_KEY=sk-unsloth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UNSLOTH_BASE_URL=http://127.0.0.1:8888

# Gate for /agent/* and /lab/* when the server is reachable off-loopback. Unset
# means loopback-only (localhost). Set a token to allow LAN clients; the web app
# must send the same value as VITE_AGENT_TOKEN.
#PENUMBRA_AGENT_TOKEN=

# HTTP port. Defaults to 3000.
#PORT=3000
