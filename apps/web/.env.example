# Copy this file to .env and edit.

# Base URL of the Penumbra sync server. Defaults to http://localhost:3000 when
# unset, which is right for running web + server on the same machine.
#
# To sync across devices on your LAN, point this at the host machine's address,
# e.g. http://192.168.1.50:3000, and start the server (it binds 0.0.0.0).
# See docs/SYNC.md.
VITE_SERVER_URL=http://localhost:3000

# Where LocalEngine finds the local OpenAI-compatible model server. The default
# matches the port the desktop sidecar spawns llama-server on (LLM_PORT in
# apps/desktop/src-tauri/src/lib.rs — keep the two in sync if you change it).
# See apps/desktop/SIDECAR.md.
#VITE_LOCAL_LLM_URL=http://127.0.0.1:8080

# Model id sent in chat requests; llama-server accepts any id for its single
# loaded model, so this rarely needs changing.
#VITE_LOCAL_LLM_MODEL=local
