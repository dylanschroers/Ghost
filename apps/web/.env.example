# Base URL of the Ghost sync server. Defaults to http://localhost:3000 when
# unset, which is right for running web + server on the same machine.
#
# To sync across devices on your LAN, point this at the host machine's address,
# e.g. http://192.168.1.50:3000, and start the server (it binds 0.0.0.0).
# Copy this file to .env and edit. See docs/SYNC.md.
VITE_SERVER_URL=http://localhost:3000
